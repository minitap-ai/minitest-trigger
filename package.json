{
  "name": "minitest-trigger",
  "version": "1.0.0",
  "description": "GitHub Action for triggering your Minitest suite from CI workflows",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "bundle": "ncc build src/main.ts --source-map --license licenses.txt",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "all": "npm run build && npm run lint && npm run format:check && npm run bundle"
  },
  "keywords": [
    "github-action",
    "minitap",
    "minitest",
    "testing",
    "mobile-testing",
    "ci-cd"
  ],
  "author": "Minitap",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/http-client": "^2.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.25.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "@eslint/js": "^9.25.1"
  }
}
